{
  "expo": {
    "name": "BranchFlow Admin",
    "slug": "branchflow-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07112c"
    },
    "android": {
      "package": "com.branchflow.admin",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#07112c"
      }
    },
    "ios": {
      "bundleIdentifier": "com.branchflow.admin",
      "supportsTablet": true
    }
  }
}
