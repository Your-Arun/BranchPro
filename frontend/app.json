{
  "expo": {
    "name": "BranchFlow Pro",
    "slug": "branchflow-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07112c"
    },
    "android": {
      "package": "com.branchflow.pro",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "navigationBar": {
        "backgroundColor": "#050f2a",
        "buttonColor": "light"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#07112c"
      }
    },
    "ios": {
      "bundleIdentifier": "com.branchflow.pro",
      "supportsTablet": true
    }
  }
}
