{
  "expo": {
    "name": "BranchFlow Pro",
    "slug": "branchflow-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07112c"
    },
    "android": {
      "package": "com.branchflow.pro",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#07112c"
      }
    },
    "androidNavigationBar": {
      "backgroundColor": "#050f2a",
      "barStyle": "light-content"
    },
    "ios": {
      "bundleIdentifier": "com.branchflow.pro",
      "supportsTablet": true
    },
    "extra": {
      "eas": {
        "projectId": "996d0de3-8166-42bd-a5ae-b96ad5fc6dca"
      }
    }
  }
}
